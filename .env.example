# MundaAI — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to GitHub

# API
SECRET_KEY=your-secret-key-here
ENVIRONMENT=development  # development | production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mundaai

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# USSD (Africa's Talking)
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=your-africastalking-username
AT_USSD_CODE=*384#

# Model paths
MODEL_PATH=./model/mundaai_model.pkl
LE_RISK_PATH=./model/le_risk.pkl
LE_CROP_PATH=./model/le_crop.pkl
LE_PROVINCE_PATH=./model/le_province.pkl
